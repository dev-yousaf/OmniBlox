generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL_POOLED")
  directUrl = env("DIRECT_URL")
}

// --- THE CORE OF MULTI-TENANCY ---

model Company {
  id           String @id @default(uuid())
  name         String
  workspaceUrl String @unique
  industry     String?
  otherIndustry String?
  country      String?
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownerId String? @unique // ID of the user who created the company (optional for initial creation)
  owner   User?   @relation("CompanyOwner", fields: [ownerId], references: [id])
  users   User[] @relation("CompanyUsers") // All users belonging to this company

  // All business data models link back to this Company
  products            Product[]
  productCategories   ProductCategory[]
  subCategories       SubCategory[]
  brands              Brand[]
  variantAttributes   VariantAttribute[]
  units               Unit[]
  warranties          Warranty[]
  warehouses          Warehouse[]
  billers             Biller[]
  customers           Customer[]
  suppliers           Supplier[]
  sales               Sale[]
  purchaseOrders      PurchaseOrder[]
  quotations          Quotation[]
  salesReturns        SalesReturn[]
  purchaseReturns     PurchaseReturn[]
  expenses            Expense[]
  expenseCategories   ExpenseCategory[]
  stockAdjustments    StockAdjustment[]
  deliveries          Delivery[]
  auditLogs           AuditLog[]

  @@map("companies")
}

// --- MODIFIED USER & CONTACT MODELS ---

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  name          String
  role          UserRole   @default(OBSERVER) // Role *within* the company
  status        UserStatus @default(ACTIVE)
  emailVerified DateTime?  // Null means not verified; set to timestamp when verified
  image         String?    // Optional profile image
  isSuperadmin  Boolean    @default(false) // Platform-level superadmin
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // MODIFIED: User now belongs to a Company
  companyId String
  company   Company @relation("CompanyUsers", fields: [companyId], references: [id])

  // Relations
  ownedCompany      Company?          @relation("CompanyOwner")
  expenses          Expense[]
  purchaseOrders    PurchaseOrder[]
  quotations        Quotation[]
  sales             Sale[]
  salesReturns      SalesReturn[]
  purchaseReturns   PurchaseReturn[]
  stockAdjustments  StockAdjustment[]
  
  // Better Auth Relations
  accounts Account[]
  sessions Session[]
  
  // Auth Token Relations
  authTokens AuthToken[]

  // Created products
  createdProducts Product[] @relation("CreatedProducts")

  auditLogs       AuditLog[]

  // Stock Ledger
  stockLedgerEntries StockLedger[]

  @@map("users")
}

// Better Auth Models
model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant session fields (populated by Better Auth databaseHooks)
  companyId String
  role      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model AuthToken {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())

  // Link to the user
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

model Biller {
  id            String       @id @default(uuid())
  name          String
  code          String
  address       String?
  phone         String?
  email         String?
  contactPerson String?
  gstNumber     String?
  status        BillerStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  sales Sale[]

  @@unique([companyId, code]) // Code unique per company
  @@map("billers")
}

model Customer {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  creditLimit Decimal? @db.Decimal(10, 2)
  balance     Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Relations
  quotations Quotation[]
  sales      Sale[]

  @@unique([companyId, email]) // Email unique per company
  @@map("customers")
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  creditLimit Decimal? @db.Decimal(10, 2)
  balance     Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Relations
  purchaseOrders   PurchaseOrder[]
  purchaseReturns  PurchaseReturn[]

  @@unique([companyId, email]) // Email unique per company
  @@map("suppliers")
}


// --- MODIFIED PRODUCT & INVENTORY MODELS ---

enum ProductType {
  STANDARD
  DIGITAL
  SERVICE
  COMBO
}

model Product {
  id           String        @id @default(uuid())
  name         String
  sku          String        // SKU should be unique *per company*
  description  String?
  type         ProductType   @default(STANDARD)
  salePrice    Decimal       @db.Decimal(10, 2)
  costPrice    Decimal       @db.Decimal(10, 2)
  unit         String        @default("pcs") // Unit of measure: pcs, kg, liters, hours, etc.
  imageUrl         String?       // Product image URL
  barcodeSymbology String        @default("CODE128") // CODE128, EAN13, UPCA, QR
  taxRate          Decimal       @default(0) @db.Decimal(5, 2) // Tax percentage
  alertQuantity    Int           @default(0) // Critical stock alert threshold
  reorderLevel     Int           @default(0)
  status           ProductStatus @default(ACTIVE)
  hasVariants  Boolean       @default(false)
  attributes   Json?         // Variant attributes like {"color": "Red", "size": "L"}
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Variant support - self relation
  parentId String?
  parent   Product?  @relation("ProductVariants", fields: [parentId], references: [id])
  variants Product[] @relation("ProductVariants")

  // Combo / Bundle support
  comboComponents    ComboItem[] @relation("ComboComponents")
  componentInCombos ComboItem[] @relation("ComboProductRefs")

  // Relations
  categoryId           String
  category             ProductCategory       @relation(fields: [categoryId], references: [id])
  brandId              String?
  brand                Brand?                @relation(fields: [brandId], references: [id])
  createdById          String?
  createdBy            User?                 @relation("CreatedProducts", fields: [createdById], references: [id])
  inventory            Inventory[]
  purchaseOrderItems   PurchaseOrderItem[]
  quotationItems       QuotationItem[]
  saleItems            SaleItem[]
  salesReturnItems     SalesReturnItem[]
  purchaseReturnItems  PurchaseReturnItem[]
  stockAdjustmentItems StockAdjustmentItem[]
  stockLedgerEntries   StockLedger[]
  subCategoryId   String?
  subCategory     SubCategory?      @relation(fields: [subCategoryId], references: [id])
  unitId          String?
  unitRef         Unit?             @relation(fields: [unitId], references: [id])
  warrantyId      String?
  warrantyRef     Warranty?         @relation(fields: [warrantyId], references: [id])
  itemCode        String?
  manufacturer    String?
  warranty        String?
  manufacturedDate DateTime?
  expiryDate      DateTime?

  @@unique([companyId, sku]) // Ensures SKU is unique only within a company
  @@map("products")
}

// Combo/Bundle items: a combo product contains other products
model ComboItem {
  id        String @id @default(uuid())
  quantity  Int    @default(1)

  comboId    String
  combo      Product @relation("ComboComponents", fields: [comboId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation("ComboProductRefs", fields: [productId], references: [id])

  @@unique([comboId, productId])
  @@map("combo_items")
}

model StockLedger {
  id        String   @id @default(uuid())
  quantity  Int      // Change in quantity (+ for additions, - for removals)
  balance   Int      // Running balance after this entry
  type      String   // ADJUSTMENT, SALE, PURCHASE, RETURN, TRANSFER
  reference String?  // Reference number or ID (sale #, PO #, etc.)
  note      String?
  createdAt DateTime @default(now())

  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([productId, warehouseId])
  @@map("stock_ledger")
}

model ProductCategory {
  id          String     @id @default(uuid())
  name        String
  slug        String
  description String?
  status      String     @default("ACTIVE") // ACTIVE | INACTIVE

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products     Product[]
  subCategories SubCategory[]

  @@unique([companyId, name])
  @@unique([companyId, slug])
  @@map("product_categories")
}

model SubCategory {
  id          String     @id @default(uuid())
  name        String
  slug        String
  code        String?
  imageUrl    String?
  description String?
  status      String     @default("ACTIVE") // ACTIVE | INACTIVE

  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products Product[]

  @@unique([companyId, name, categoryId])
  @@unique([companyId, slug])
  @@map("sub_categories")
}

model Brand {
  id          String     @id @default(uuid())
  name        String
  slug        String
  imageUrl    String?
  description String?
  status      String     @default("ACTIVE") // ACTIVE | INACTIVE

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products Product[]

  @@unique([companyId, name])
  @@unique([companyId, slug])
  @@map("brands")
}

model VariantAttribute {
  id          String     @id @default(uuid())
  name        String
  slug        String
  values      Json?      // ["Red", "Blue", "Green"]
  description String?
  status      String     @default("ACTIVE")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@unique([companyId, slug])
  @@map("variant_attributes")
}

model Unit {
  id          String     @id @default(uuid())
  name        String     // "Pieces"
  shortName   String     // "pcs"
  slug        String
  description String?
  status      String     @default("ACTIVE")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products Product[]

  @@unique([companyId, name])
  @@unique([companyId, shortName])
  @@unique([companyId, slug])
  @@map("units")
}

model Warranty {
  id           String     @id @default(uuid())
  name         String     // "Standard Warranty"
  duration     Int        // 12
  durationType String     @default("MONTHS") // DAYS | MONTHS | YEARS
  description  String?
  status       String     @default("ACTIVE")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products Product[]

  @@unique([companyId, name])
  @@map("warranties")
}

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Relations
  inventory            Inventory[]
  stockAdjustmentItems StockAdjustmentItem[]
  salesReturns         SalesReturn[]
  purchaseReturns      PurchaseReturn[]
  sales                Sale[]
  purchases            PurchaseOrder[]
  stockLedgerEntries   StockLedger[]

  @@map("warehouses")
}

model Inventory {
  productId   String
  warehouseId String
  quantity    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@id([productId, warehouseId])
  @@index([warehouseId])
  @@index([quantity])
  @@map("inventory")
}

model StockAdjustment {
  id              String   @id @default(uuid())
  referenceNumber String
  adjustmentDate  DateTime @default(now())
  notes           String?
  documentUrl     String?  // Attached document/image
  type            String   @default("ADDITION") // ADDITION or REMOVAL
  totalItems      Int      @default(0)
  netChange       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Relations
  userId String
  user   User                 @relation(fields: [userId], references: [id])
  items  StockAdjustmentItem[]

  @@unique([companyId, referenceNumber]) // Reference number unique per company
  @@index([userId])
  @@index([companyId, adjustmentDate])
  @@map("stock_adjustments")
}

model StockAdjustmentItem {
  id                String          @id @default(uuid())
  previousQuantity  Int
  newQuantity       Int
  difference        Int
  stockAdjustmentId String
  productId         String
  warehouseId       String
  stockAdjustment   StockAdjustment @relation(fields: [stockAdjustmentId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id])
  warehouse         Warehouse       @relation(fields: [warehouseId], references: [id])

  @@map("stock_adjustment_items")
}


// --- MODIFIED TRANSACTION & EXPENSE MODELS ---

model Expense {
  id          String    @id @default(uuid())
  reference   String
  amount      Decimal   @db.Decimal(10, 2)
  expenseDate DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  description String?   // Renamed from 'notes'
  vendor      String    // New field for the vendor name
  status      ExpenseStatus   @default(PENDING) // New status field
  paymentMethod PaymentMethod?  // New field for payment method

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Foreign Keys
  categoryId String
  userId     String
  purchaseOrderId String?  // Link expense to a purchase order
  saleId          String?  // Link expense to a sale

  // Relations
  category      ExpenseCategory     @relation(fields: [categoryId], references: [id])
  user          User                @relation(fields: [userId], references: [id])
  purchaseOrder PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id])
  sale          Sale?               @relation(fields: [saleId], references: [id])
  attachments   ExpenseAttachment[] // Relation to new attachments model

  @@index([categoryId])
  @@index([userId])
  @@index([companyId, expenseDate])
  @@map("expenses")
}

model ExpenseAttachment {
  id        String   @id @default(uuid())
  url       String 
  fileName  String
  fileType  String
  createdAt DateTime @default(now())

  // Relation to Expense
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id])

  @@map("expense_attachments")
}

model ExpenseCategory {
  id          String  @id @default(uuid())
  name        String
  description String?

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Relations
  expenses Expense[]

  @@unique([companyId, name]) // Category names unique per company
  @@map("expense_categories")
}

// --- OTHER TRANSACTION MODELS ---

model Sale {
  id            String         @id @default(uuid())
  invoiceNumber String
  subtotal      Decimal        @db.Decimal(10, 2)
  tax           Decimal        @db.Decimal(10, 2) @default(0)
  discount      Decimal        @db.Decimal(10, 2) @default(0)
  totalAmount   Decimal        @db.Decimal(10, 2)
  status        OrderStatus    @default(PENDING)
  paymentStatus PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  saleDate      DateTime       @default(now())
  dueDate       DateTime
  notes         String?
  shippingAddress String?
  sourceQuotationId String?    // Track which quotation this sale was created from
  hasReturns    Boolean        @default(false)  // Track if any items have been returned
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customerEmail String?

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Foreign Keys
  customerId String
  userId     String
  billerId   String?
  warehouseId String?

  // Relations
  items    SaleItem[]
  customer Customer @relation(fields: [customerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  biller   Biller?  @relation(fields: [billerId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  delivery Delivery?
  returns  SalesReturn[]  // Track returns for this sale
  expenses Expense[]      // Expenses linked to this sale

  @@unique([companyId, invoiceNumber]) // Invoice number unique per company
  @@index([customerId])
  @@index([userId])
  @@index([warehouseId])
  @@index([companyId, saleDate])
  @@index([companyId, status])
  @@index([companyId, paymentStatus])
  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid())
  quantity  Int
  returnedQuantity Int @default(0)  // Track how many items have been returned
  unitPrice Decimal @db.Decimal(10, 2)
  saleId    String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  returnedItems SalesReturnItem[]  // Track returns for this item

  @@index([productId])
  @@index([saleId])
  @@index([productId, saleId])
  @@map("sale_items")
}

model Delivery {
  id              String          @id @default(uuid())
  status          DeliveryStatus  @default(PENDING)
  trackingNumber  String?
  deliveryAddress String          // Copied from the sale for historical accuracy
  dispatchDate    DateTime?
  deliveredDate   DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // --- Relations ---
  saleId    String   @unique // Creates a one-to-one relationship
  sale      Sale     @relation(fields: [saleId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("deliveries")
}

model PurchaseOrder {
  id              String              @id @default(uuid())
  referenceNumber String
  billNumber      String?             // Supplier invoice/bill number
  billDate        DateTime?           // When the bill was received
  dueDate         DateTime?           // Payment due date
  paymentStatus   PaymentStatus       @default(PENDING)
  paymentMethod   PaymentMethod?
  notes           String?
  totalAmount     Decimal             @db.Decimal(10, 2)
  status          OrderStatus         @default(PENDING)
  orderDate       DateTime            @default(now())
  hasReturns      Boolean             @default(false)  // Track if any items have been returned
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Foreign Keys
  supplierId String
  userId     String
  warehouseId String?

  // Relations
  items    PurchaseOrderItem[]
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  user     User                @relation(fields: [userId], references: [id])
  warehouse Warehouse?         @relation(fields: [warehouseId], references: [id])
  returns  PurchaseReturn[]    // Track returns for this purchase
  expenses Expense[]           // Expenses linked to this purchase

  @@unique([companyId, referenceNumber]) // Reference number unique per company
  @@index([supplierId])
  @@index([userId])
  @@index([companyId, orderDate])
  @@index([companyId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  quantity        Int
  returnedQuantity Int          @default(0)  // Track how many items have been returned
  unitCost        Decimal       @db.Decimal(10, 2)
  purchaseOrderId String
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  returnedItems   PurchaseReturnItem[]  // Track returns for this item

  @@map("purchase_order_items")
}

model Quotation {
  id              String          @id @default(uuid())
  referenceNumber String
  totalAmount     Decimal         @db.Decimal(10, 2)
  status          OrderStatus     @default(PENDING)
  quoteDate       DateTime        @default(now())
  expiryDate      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Foreign Keys
  customerId String
  userId     String

  // Relations
  items    QuotationItem[]
  customer Customer        @relation(fields: [customerId], references: [id])
  user     User            @relation(fields: [userId], references: [id])

  @@unique([companyId, referenceNumber]) // Reference number unique per company
  @@index([customerId])
  @@index([userId])
  @@index([companyId, quoteDate])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(uuid())
  quantity    Int
  unitPrice   Decimal   @db.Decimal(10, 2)
  quotationId String
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

model SalesReturn {
  id              String       @id @default(uuid())
  referenceNumber String
  totalAmount     Decimal      @db.Decimal(10, 2)
  reason          String?
  status          ReturnStatus @default(PENDING)
  warehouseId     String
  returnDate      DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // NEW: Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Optional: Link to original Sale
  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id])

  // Foreign Keys
  userId String

  // Relations
  items     SalesReturnItem[]
  user      User              @relation(fields: [userId], references: [id])
  warehouse Warehouse         @relation(fields: [warehouseId], references: [id])

  @@unique([companyId, referenceNumber]) // Reference number unique per company
  @@index([saleId])
  @@index([companyId, returnDate])
  @@map("sales_returns")
}

model SalesReturnItem {
  id            String      @id @default(uuid())
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  salesReturnId String
  productId     String
  
  // Optional: Link to original SaleItem for tracking
  saleItemId String?
  saleItem   SaleItem? @relation(fields: [saleItemId], references: [id])
  
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  @@map("sales_return_items")
}

model PurchaseReturn {
  id              String              @id @default(uuid())
  referenceNumber String
  totalAmount     Decimal             @db.Decimal(10, 2)
  reason          String?
  status          ReturnStatus        @default(PENDING)
  warehouseId     String
  supplierId      String
  returnDate      DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Link to Company
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Optional: Link to original PurchaseOrder
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // Foreign Keys
  userId String

  // Relations
  items     PurchaseReturnItem[]
  user      User                 @relation(fields: [userId], references: [id])
  warehouse Warehouse            @relation(fields: [warehouseId], references: [id])
  supplier  Supplier             @relation(fields: [supplierId], references: [id])

  @@unique([companyId, referenceNumber])
  @@index([companyId, returnDate])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  quantity         Int
  unitPrice        Decimal        @db.Decimal(10, 2)
  purchaseReturnId String
  productId        String
  
  // Optional: Link to original PurchaseOrderItem for tracking
  purchaseOrderItemId String?
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)

  @@map("purchase_return_items")
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  userName  String
  userRole  String
  action    String   // CREATE, UPDATE, DELETE, MARK_PAID, RECEIVE, LOGIN, etc.
  entity    String   // Sale, Purchase, Product, Customer, Supplier, etc.
  entityId  String?
  details   String?  // JSON string with extra context
  ipAddress String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, entity, entityId])
  @@map("audit_logs")
}

